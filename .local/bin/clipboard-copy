#!/usr/bin/env zsh
# Original found here: https://blog.d46.us/zsh-tmux-emacs-copy-paste/

# Copies data to clipboard from stdin.
function clipboard-copy() {
  emulate -L zsh

  if [[ "$(uname -s)" == "Darwin" ]]; then
    pbcopy
  elif [[ -n "$WAYLAND_DISPLAY" ]] && (( $+commands[wl-copy] )); then
    wl-copy
  elif (( $+commands[xclip] )); then
    xclip -in -selection clipboard
  elif (( $+commands[xsel] )); then
    xsel --clipboard --input
  else
    print "clipboard-copy: Platform $(uname -s) not supported or wl-copy/xclip/xsel not installed" >&2
    return 1
  fi
}

clipboard-copy $@
